# PX Tunnel — configuration (copy to .env / set in the systemd unit). All optional unless noted.

# Headscale server_url used in device join commands, e.g. https://headscale.example.com
# Strongly recommended — empty shows a placeholder in the generated join command.
PXTUNNEL_LOGIN_SERVER=

# Product/brand name shown in the UI (white-label).
PXTUNNEL_BRAND=PX Tunnel

# Reserved "infrastructure" tenant: raw WireGuard / system links group here; it cannot be
# deleted or granted to non-superadmins.
PXTUNNEL_INFRA_TENANT=system

# Where the aggregator listens (loopback by default; front it with a TLS reverse proxy).
PXTUNNEL_BIND=127.0.0.1:8807

# Set to 1 when a TLS reverse proxy fronts the dashboard (enables the Secure cookie flag).
PXTUNNEL_COOKIE_SECURE=0

# Storage paths.
PXTUNNEL_DB=/etc/pxtunnel/pxtunnel.db
PXTUNNEL_STATE=/run/pxtunnel/state.json
PXTUNNEL_PURPOSES=/etc/pxtunnel/purposes.yaml

# Tuning.
PXTUNNEL_SESSION_TTL=604800     # session lifetime, seconds (7 days)
PXTUNNEL_MIN_PW=8               # minimum password length
PXTUNNEL_PBKDF2_ITER=600000     # PBKDF2-SHA256 iterations
# Snapshot staleness (s) before the api re-runs the collector itself. Keep HIGH under systemd:
# the collector timer already refreshes every 15s WITH CAP_NET_ADMIN; the api has no such
# capability, so a low value here would make it overwrite the snapshot without WireGuard data.
PXTUNNEL_MAX_AGE=600
PXTUNNEL_MAX_BODY=1048576       # max request body bytes (1 MiB)
